# Copy this block into ~/.codex/config.toml (or a trusted project's .codex/config.toml)
# after installing glm-mcp-codex. Use forward-slash absolute paths on Windows.

[mcp_servers.glm]
command = "node"
args = ["/absolute/path/to/glm-mcp-codex/glm-server.mjs"]
cwd = "/absolute/path/to/.codex/glm-mcp"
env_vars = ["GLM_API_KEY", "ANTHROPIC_AUTH_TOKEN"]
startup_timeout_sec = 20
tool_timeout_sec = 1800
default_tools_approval_mode = "prompt"
required = false

[mcp_servers.glm.tools.glm_status]
approval_mode = "approve"

[mcp_servers.glm.tools.glm_recommend]
approval_mode = "approve"
